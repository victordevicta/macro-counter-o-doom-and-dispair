# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/macro_counter_doom?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Nutritionix API
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_APP_KEY=your-nutritionix-app-key

# USDA FoodData Central
USDA_API_KEY=your-usda-api-key

# Open Food Facts (no key needed, but can set base URL)
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
