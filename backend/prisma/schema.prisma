generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum Goal {
  LOSE_WEIGHT
  MAINTAIN
  GAIN_MUSCLE
}

enum Sex {
  MALE
  FEMALE
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum FoodSource {
  NUTRITIONIX
  OPEN_FOOD_FACTS
  USDA
  CUSTOM
  USER_CREATED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  goals         NutritionGoal?
  foodEntries   FoodEntry[]
  weightLogs    WeightLog[]
  favoriteFoods FavoriteFood[]
  customFoods   Food[]         @relation("UserCreatedFoods")
  meals         SavedMeal[]
  refreshTokens RefreshToken[]
  userTheme     UserTheme?
  achievements  Achievement[]

  @@map("users")
}

model UserProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String?
  lastName      String?
  avatar        String?
  dateOfBirth   DateTime?
  sex           Sex?
  heightCm      Float?
  currentWeight Float?
  activityLevel ActivityLevel @default(SEDENTARY)
  goal          Goal          @default(MAINTAIN)
  onboardingDone Boolean      @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("user_profiles")
}

model NutritionGoal {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calories        Int      @default(2000)
  proteinG        Float    @default(150)
  carbsG          Float    @default(200)
  fatG            Float    @default(65)
  fiberG          Float    @default(25)
  waterMl         Int      @default(2500)
  sodiumMg        Float    @default(2300)
  sugarG          Float?
  saturatedFatG   Float?
  cholesterolMg   Float?
  potassiumMg     Float?
  calciumMg       Float?
  ironMg          Float?
  vitaminCMg      Float?
  vitaminDMcg     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("nutrition_goals")
}

model Food {
  id              String     @id @default(cuid())
  externalId      String?
  source          FoodSource @default(CUSTOM)
  barcode         String?
  name            String
  brand           String?
  imageUrl        String?
  servingSize     Float      @default(100)
  servingUnit     String     @default("g")
  servingName     String?
  calories        Float      @default(0)
  proteinG        Float      @default(0)
  carbsG          Float      @default(0)
  fatG            Float      @default(0)
  fiberG          Float?
  sugarG          Float?
  sodiumMg        Float?
  saturatedFatG   Float?
  transFatG       Float?
  cholesterolMg   Float?
  potassiumMg     Float?
  calciumMg       Float?
  ironMg          Float?
  vitaminCMg      Float?
  vitaminDMcg     Float?
  magnesiumMg     Float?
  zincMg          Float?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  createdById     String?
  createdBy       User?      @relation("UserCreatedFoods", fields: [createdById], references: [id])

  foodEntries     FoodEntry[]
  favoritedBy     FavoriteFood[]
  mealItems       MealItem[]

  @@unique([externalId, source])
  @@index([barcode])
  @@index([name])
  @@map("foods")
}

model FoodEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food     @relation(fields: [foodId], references: [id])
  date        DateTime @db.Date
  mealType    MealType
  servings    Float    @default(1)
  servingSize Float
  servingUnit String   @default("g")
  calories    Float
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float?
  sodiumMg    Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@map("food_entries")
}

model WeightLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg       Float
  bodyFatPercent Float?
  muscleMassKg   Float?
  notes          String?
  loggedAt       DateTime @default(now())

  @@index([userId, loggedAt])
  @@map("weight_logs")
}

model FavoriteFood {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@map("favorite_foods")
}

model SavedMeal {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  mealType  MealType   @default(LUNCH)
  items     MealItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("saved_meals")
}

model MealItem {
  id          String    @id @default(cuid())
  mealId      String
  meal        SavedMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food      @relation(fields: [foodId], references: [id])
  servings    Float     @default(1)
  servingSize Float
  servingUnit String    @default("g")

  @@map("meal_items")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model UserTheme {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId        String   @default("dark-fantasy")
  companionId    String   @default("necromancer")
  unlockedThemes String[] @default(["dark-fantasy", "clean"])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_themes")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  icon        String   @default("🏆")
  unlockedAt  DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@map("achievements")
}
