{
  "expo": {
    "name": "Macro Counter O' Doom",
    "slug": "macro-counter-doom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.doomvault.macrocounter",
      "infoPlist": {
        "NSCameraUsageDescription": "The scanner requires your camera to read the cursed barcodes.",
        "NSPhotoLibraryUsageDescription": "Required to access your progress photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.doomvault.macrocounter",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "The scanner requires your camera to decipher the cursed barcodes."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "macrocounterdoom",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
